{
  "expo": {
    "name": "Ping Logger",
    "slug": "ping-logger",
    "version": "0.1.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinglogger",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.anonymous.pinglogger",
      "buildNumber": "5"
    },
    "android": {
      "permissions": [
        "INTERNET",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#152024",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.pinglogger",
      "versionCode": 5
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-notifee-android-maven",
      "./plugins/with-notifee-foreground-service",
      "./plugins/with-public-export-module",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#152024",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
